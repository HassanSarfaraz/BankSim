# ===========================================================================
# SecureBank — Environment Configuration
# Copy this file to .env and edit values for your local setup.
# ===========================================================================

# Flask
SECRET_KEY=securebank-dev-secret-2026-very-secure-32bytes-long-key
JWT_SECRET_KEY=jwt-securebank-key-2026-very-secure-32bytes-long-key

# PostgreSQL (install locally, create database 'securebank')
DB_USER=postgres
DB_PASSWORD=1295
DB_HOST=LocalHost
DB_PORT=5432
DB_NAME=securebank

# MongoDB (install locally, runs on default port)
MONGO_URI=mongodb://localhost:27017/securebank_audit

# API base URL (used by the Tkinter frontend)
API_BASE_URL=http://localhost:5000/api
